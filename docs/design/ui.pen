                      "id": "6pEOu",
                      "name": "Article Body",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "padding": [
                        24,
                        0,
                        0,
                        0
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "0Vm0I",
                          "name": "para0",
                          "fill": "#404040",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Rust 的所有权系统是其最独特的特性之一，它在不需要垃圾回收器的情况下保证了内存安全。理解所有权规则对于编写高效、安全的 Rust 代码至关重要。",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "uiZAH",
                          "name": "h2_1",
                          "fill": "#0A0A0A",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "所有权的三条基本规则",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 18,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "7fW7L",
                          "name": "para1",
                          "fill": "#404040",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Rust 的所有权系统遵循三条基本规则：每个值都有一个变量作为其所有者；同一时刻，一个值只能有一个所有者；当所有者超出作用域时，这个值将被丢弃（内存被释放）。",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "3o61l",
                          "name": "Code Block",
                          "width": "fill_container",
                          "fill": "#1E1E2E",
                          "cornerRadius": 8,
                          "layout": "vertical",
                          "gap": 4,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "eW73v",
                              "name": "codeLine1",
                              "fill": "#CDD6F4",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "fn main() {",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "fnNcO",
                              "name": "codeLine2",
                              "fill": "#CDD6F4",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    let s1 = String::from(\"hello\");",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "KtKWQ",
                              "name": "codeLine3",
                              "fill": "#6C7086",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    let s2 = s1; // s1 的所有权移动到 s2",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "HBqqP",
                              "name": "codeLine4",
                              "fill": "#F38BA8",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    // println!(\"{}\", s1); // 错误！s1 已无效",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "wVqGc",
                              "name": "codeLine5",
                              "fill": "#A6E3A1",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    println!(\"{}\", s2); // 正常",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "L4cLu",
                              "name": "codeLine6",
                              "fill": "#CDD6F4",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "}",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "NYh4S",
                          "name": "h2_2",
                          "fill": "#0A0A0A",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "借用与引用",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 18,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "R3aCq",
                          "name": "para2",
                          "fill": "#404040",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "借用（Borrowing）允许你在不转移所有权的情况下使用一个值。通过引用（References），你可以将值的引用传递给函数，函数使用完毕后，所有权不会被转移。",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
